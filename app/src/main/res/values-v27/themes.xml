<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Geonex.Dark" parent="Theme.Material3.Dark.NoActionBar">

        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_darker</item>
        <item name="colorPrimaryContainer">@color/primary_container_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/secondary_dark</item>
        <item name="colorSecondaryVariant">@color/secondary_darker</item>
        <item name="colorSecondaryContainer">@color/secondary_container_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_dark</item>

        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- ===== GLOBAL FONT ===== -->
        <item name="android:fontFamily">@font/dm_sans_regular</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Geonex.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Geonex.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Geonex.Large</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Geonex.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Geonex.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Geonex.HeadlineSmall</item>

        <item name="android:windowBackground">@color/background_dark</item>
    </style>
</resources>