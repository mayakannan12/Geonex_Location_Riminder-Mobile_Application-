<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- ===== BACKGROUND ATMOSPHERE - FLOATING ORBS ===== -->
    <View
        android:id="@+id/orb1"
        android:layout_width="500dp"
        android:layout_height="500dp"
        android:layout_marginTop="-100dp"
        android:layout_marginStart="-150dp"
        android:background="@drawable/orb_blue"
        android:alpha="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/orb2"
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_marginBottom="-80dp"
        android:layout_marginEnd="-120dp"
        android:background="@drawable/orb_purple"
        android:alpha="0.30"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/orb3"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/orb_violet"
        android:alpha="0.20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== TWINKLING PARTICLES CONTAINER ===== -->
    <FrameLayout
        android:id="@+id/particleContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent" />

    <!-- ===== TOP BAR - GLASS MORPHISM ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/top_bar_glass"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- App Logo: GEONEX with gold X -->
        <LinearLayout
            android:id="@+id/logoContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GEON"
                style="@style/TextAppearance.Onboarding.Logo"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E"
                style="@style/TextAppearance.Onboarding.Logo"
                android:textColor="@color/gold_gradient_start" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="X"
                style="@style/TextAppearance.Onboarding.Logo"
                android:textColor="@color/gold_gradient_end" />
        </LinearLayout>

        <!-- Skip Button - Pill Style (FIXED: Removed duplicate style) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/skip_pill_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="@string/onboarding_skip"
            android:textAllCaps="false"
            style="@style/TextAppearance.Onboarding.Skip"
            android:textColor="@color/text_bullet"
            app:icon="@drawable/ic_arrow_right"
            app:iconGravity="textEnd"
            app:iconTint="@color/text_bullet"
            app:iconPadding="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/glass_border" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===== MAIN CONTENT AREA ===== -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/dotsRow"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        tools:ignore="UnknownId" />

    <!-- ===== DOTS INDICATOR ROW ===== -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="center_horizontal"
        android:animateLayoutChanges="true"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:tabBackground="@drawable/tab_selector_premium"
        app:tabGravity="center"
        app:tabIndicatorHeight="0dp"
        app:tabPadding="0dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingEnd="0dp"
        app:tabMinWidth="0dp"
        app:tabMaxWidth="26dp" />

    <!-- ===== BOTTOM BAR - GLASS MORPHISM ===== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bottom_bar_glass"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Previous Circle Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevious"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/circle_nav_bg"
            android:visibility="gone"
            app:icon="@drawable/ic_arrow_left"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconTint="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/glass_border"
            style="@style/Widget.Material3.Button.TextButton" />

        <!-- Next Button (White Pill) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:background="@drawable/button_gradient_white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/onboarding_next"
            android:textAllCaps="false"
            style="@style/TextAppearance.Onboarding.Button"
            android:textColor="@color/white_button_text"
            app:icon="@drawable/ic_arrow_right"
            app:iconGravity="textEnd"
            app:iconTint="@color/white_button_text"
            app:iconPadding="4dp"
            android:stateListAnimator="@animator/button_pulse"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNextIcon"
            app:layout_constraintStart_toEndOf="@id/btnPrevious"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/glass_border" />

        <!-- Get Started Button (Gold Pill) - Initially Gone -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGetStarted"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:background="@drawable/button_gradient_gold"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/onboarding_get_started"
            android:textAllCaps="false"
            style="@style/TextAppearance.Onboarding.Button"
            android:textColor="@color/gold_text"
            android:visibility="gone"
            app:icon="@drawable/ic_star"
            app:iconGravity="textEnd"
            app:iconTint="@color/gold_text"
            app:iconPadding="4dp"
            android:stateListAnimator="@animator/button_gold_pulse"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnNextIcon"
            app:layout_constraintStart_toEndOf="@id/btnPrevious"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/gold_gradient_end" />

        <!-- Next Icon Circle Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextIcon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/circle_nav_bg"
            android:visibility="gone"
            app:icon="@drawable/ic_arrow_right"
            app:iconGravity="textEnd"
            app:iconSize="18dp"
            app:iconTint="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rippleColor="@color/glass_border"
            style="@style/Widget.Material3.Button.TextButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>