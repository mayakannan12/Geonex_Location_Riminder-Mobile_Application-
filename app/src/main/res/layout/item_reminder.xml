<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardReminder"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    android:stateListAnimator="@animator/card_elevation_small"
    android:animateLayoutChanges="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/surface"
    android:transitionName="reminder_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:baselineAligned="false"
        android:animateLayoutChanges="true">

        <!-- Card Header with Category and Menu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false"
            android:animateLayoutChanges="true">

            <TextView
                android:id="@+id/tvCategoryBadge"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:text="@string/category_grocery"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/category_badge_bg"
                android:layout_marginEnd="8dp"
                android:alpha="0.9"
                android:transitionName="category_badge"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/category_badge_description" />

            <TextView
                android:id="@+id/tvRecurringBadge"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center"
                android:text="@string/recurring_badge_daily"
                android:textSize="10sp"
                android:background="@drawable/recurring_badge_bg"
                android:visibility="gone"
                android:layout_marginEnd="8dp"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/recurring_badge_description"
                tools:ignore="SmallSp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Fixed: Touch target size increased to 48x48 -->
            <LinearLayout
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:transitionName="menu_button"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/menu_button_description">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⋮"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:focusable="false" />

            </LinearLayout>

        </LinearLayout>

        <!-- Reminder Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/buy_milk_amp_eggs"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:transitionName="reminder_title"
            android:importantForAccessibility="yes"
            android:contentDescription="@string/title_description" />

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:baselineAligned="false"
            android:animateLayoutChanges="true">

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="📍"
                android:textSize="14sp"
                android:layout_marginEnd="4dp"
                android:alpha="0.8"
                android:importantForAccessibility="no"
                android:focusable="false" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/reliance_fresh_andheri_east"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:transitionName="reminder_location"
                android:importantForAccessibility="yes"
                android:contentDescription="@string/location_description" />

        </LinearLayout>

        <!-- Mini Map Preview (Hidden by default) -->
        <FrameLayout
            android:id="@+id/mapPreview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            android:layout_marginBottom="8dp"
            android:background="@drawable/map_preview_bg"
            android:animateLayoutChanges="true"
            android:importantForAccessibility="no">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="📍"
                android:textSize="28sp"
                android:textColor="@color/primary"
                android:layout_gravity="center"
                android:elevation="4dp"
                android:alpha="0.8"
                android:importantForAccessibility="no" />

            <!-- Shimmer effect overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shimmer_effect"
                android:visibility="gone"
                android:importantForAccessibility="no" />

        </FrameLayout>

        <!-- Footer with Radius and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:baselineAligned="false"
            android:animateLayoutChanges="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:text="⏱️"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.7"
                    android:importantForAccessibility="no"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/just_now"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:transitionName="reminder_time"
                    android:importantForAccessibility="yes"
                    android:contentDescription="@string/time_description" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/radius_badge_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:text="📏"
                    android:textSize="10sp"
                    android:layout_marginEnd="4dp"
                    android:alpha="0.7"
                    android:importantForAccessibility="no"
                    android:focusable="false" />

                <TextView
                    android:id="@+id/tvRadius"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/radius_500m"
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:textStyle="bold"
                    android:transitionName="reminder_radius"
                    android:importantForAccessibility="yes"
                    android:contentDescription="@string/radius_description" />

            </LinearLayout>

        </LinearLayout>

        <!-- Completed Overlay (shown when completed) -->
        <FrameLayout
            android:id="@+id/completedOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E6FFFFFF"
            android:visibility="gone"
            android:layout_gravity="center"
            android:animateLayoutChanges="true"
            android:alpha="0.9"
            android:importantForAccessibility="no">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/completed_badge_bg"
                android:padding="12dp"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="✅"
                    android:textSize="32sp"
                    android:alpha="0.9"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/completed"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/success"
                    android:layout_marginTop="4dp"
                    android:importantForAccessibility="yes"
                    android:contentDescription="@string/completed_description" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>